# Provide a comma-separated list of GitHub Personal Access Tokens
# Multiple tokens are used to significantly bypass API rate limits.
GITHUB_TOKENS=ghp_token1,ghp_token2,ghp_token3

# Proxy settings (optional)
HTTPS_PROXY=

# Telegram monitoring settings (optional)
# Set these to receive progress updates and alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
